# ============================================================
#  COSINT MCP – Environment Configuration
#  Copy this file to ".env" and fill in what you need.
#  Missing keys only disable the affected tools.
# ============================================================

# ── Runtime / default model ──────────────────────────────────

# Default model used by cosint.py when --model is not passed
OSINT_MODEL=

# ── LiteLLM provider setup ───────────────────────────────────
# Set only the vars needed for the provider backing OSINT_MODEL.
# Common presets used by setup_env.py:
#   - OpenAI     -> OPENAI_API_KEY
#   - Anthropic  -> ANTHROPIC_API_KEY
#   - Gemini     -> GEMINI_API_KEY
# For other providers (Azure, Bedrock, Vertex, OpenRouter, etc.), see:
# https://docs.litellm.ai/docs/providers

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Gemini
GEMINI_API_KEY=

# Example custom-provider vars you might need (leave empty unless used)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# ── Essential (most frequently used) ────────────────────────

# HaveIBeenPwned – breach checks
# https://haveibeenpwned.com/API/Key
HIBP_KEY=

# Hunter.io – email & domain research
# https://hunter.io/api
HUNTER_API_KEY=

# Shodan – port & service scanning
# https://account.shodan.io/
SHODAN_KEY=

# AbuseIPDB – IP reputation
# https://www.abuseipdb.com/account/api
ABUSEIPDB_KEY=

# VirusTotal – malware & reputation
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_KEY=

# SecurityTrails – DNS history & passive DNS
# https://securitytrails.com/app/account/credentials
SECURITYTRAILS_KEY=

# ── Important for specific categories ───────────────────────

# Etherscan – Ethereum blockchain
# https://etherscan.io/myapikey
ETHERSCAN_KEY=

# NewsAPI – news search
# https://newsapi.org/register
NEWSAPI_KEY=

# Bundestag DIP API
# https://dip.bundestag.de/über-dip/hilfe/api
BUNDESTAG_DIP_KEY=

# CourtListener – public court records
# https://www.courtlistener.com/api/
COURT_LISTENER_KEY=

# GitHub Token – raises rate limits for GitHub lookups
# https://github.com/settings/tokens
GITHUB_TOKEN=

# LeakCheck – breach database
# https://leakcheck.io/
LEAKCHECK_KEY=

# IntelX – darknet & paste sites
# https://intelx.io/account?tab=developer
INTELX_KEY=

# ── Optional (extends functionality) ────────────────────────

# ipinfo.io – IP geolocation
# https://ipinfo.io/account/token
IPINFO_TOKEN=

# WhoisXMLAPI – WHOIS data
# https://user.whoisxmlapi.com/products
WHOISXML_KEY=

# OpenCorporates – company registry
# https://api.opencorporates.com/
OPENCORPORATES_KEY=

# Northdata – DACH company registry
# https://www.northdata.com/data/api
NORTHDATA_KEY=

# EmailRep.io – email reputation
# https://emailrep.io/key
EMAILREP_KEY=

# Adzuna – job listings
# https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Google Vision API – reverse image search
# https://console.cloud.google.com/
GOOGLE_VISION_KEY=

# TinEye – reverse image search
# https://services.tineye.com/TinEyeAPI
TINEYE_KEY=

# SauceNAO – reverse image search
# https://saucenao.com/user.php?page=search-api
SAUCENAO_KEY=

# FullContact – person enrichment
# https://platform.fullcontact.com/
FULLCONTACT_KEY=

# Alchemy – NFT & blockchain data
# https://dashboard.alchemy.com/
ALCHEMY_KEY=

# OpenSea – NFT marketplace
# https://docs.opensea.io/reference/api-keys
OPENSEA_KEY=

# Blockchair – multi-chain blockchain
# https://blockchair.com/api
BLOCKCHAIR_KEY=

# OpenCage – geocoding
# https://opencagedata.com/api
OPENCAGE_KEY=

# NumVerify – phone number lookup
# https://numverify.com/dashboard
NUMVERIFY_KEY=

# IPHub – VPN / proxy detection
# https://iphub.info/api
IPHUB_KEY=

# Wappalyzer – tech stack detection
# https://www.wappalyzer.com/api/
WAPPALYZER_KEY=

# Reddit API
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=osint_mcp/1.0

# Twitter API
# https://developer.twitter.com/en/docs/authentication/oauth-2-0/bearer-tokens
TWITTER_BEARER_TOKEN=

# Twitch API
# https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube API
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# VK API
# https://vk.com/dev/access_token
VK_ACCESS_TOKEN=

# Spotify API
# https://developer.spotify.com/dashboard/applications
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# SoundCloud API
# https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=

# Tumblr API
# https://www.tumblr.com/oauth/apps
TUMBLR_API_KEY=

# Flickr API
# https://www.flickr.com/services/api/misc.api_keys.html
FLICKR_API_KEY=

# Gravatar API
# https://en.gravatar.com/site/implement/hash/
GRAVATAR_API_KEY=

# StackExchange API
# https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=

# Instagram Account (for instaloader, if used and at your own risk – may trigger 2FA) or bans if abused)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# OCR.space API key for image text extraction
# https://ocr.space/ocrapi
OCR_SPACE_KEY=
